{
  "name": "onetimeshare",
  "version": "1.0.0",
  "description": "Share secrets via one-time links",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/server.ts",
    "dev:client": "vite",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:client\"",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc",
    "preview": "vite preview",
    "start": "node dist/server.js",
    "test": "npm run test:integration",
    "test:integration": "bash tests/integration-simple.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vancehenricks/onetimeshare.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/vancehenricks/onetimeshare/issues"
  },
  "homepage": "https://github.com/vancehenricks/onetimeshare#readme",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
